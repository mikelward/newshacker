{
  "ignoreCommand": "! git diff HEAD^ HEAD --name-only | grep -qvE '\\.md$'",
  "rewrites": [
    {
      "source": "/item/:id",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i)(whatsapp/.*|.*(facebookexternalhit|facebookcatalog|twitterbot|slackbot|discordbot|telegrambot|linkedinbot|skypeuripreview|embedly|redditbot|bluesky|applebot|googlebot|bingbot|duckduckbot|yandex|baiduspider|vkshare|w3c_validator|opengraph).*)"
        }
      ],
      "destination": "/api/og?id=:id"
    },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/warm-summaries?feed=top&n=30", "schedule": "*/5 * * * *" }
  ]
}
