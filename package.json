    "@tanstack/react-query-persist-client": "^5.101.2",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "node-html-parser": "^7.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "sanitize-html": "^2.17.4",
    "workbox-window": "^7.4.0"
