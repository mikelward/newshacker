    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "fake-indexeddb": "^6.2.5",
    "globals": "^15.11.0",
    "happy-dom": "^20.10.6",
    "msw": "^2.14.6",
    "sharp": "^0.34.5",
